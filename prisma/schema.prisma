// Prisma schema for JalRakshak AI — MongoDB
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ── Device: one per IoT node, managed from admin dashboard ─────────────────
model Device {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  deviceId    String   @unique          // TTN device_id e.g. "hydro-monitor-01"
  deviceName  String   @default("")
  isActive    Boolean  @default(true)   // soft-delete / disable
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Cached latest sensor values (updated on every webhook/relay sync)
  lastTemperature  Float?
  lastPh           Float?
  lastTds          Float?
  lastTurbidity    Float?
  lastConductivity Float?
  rssi             Int?
  snr              Float?
  spreadingFactor  Int?
  totalReadings    Int    @default(0)

  readings     Reading[]
  chatMessages ChatMessage[]

  @@map("devices")
}

// ── Reading: one per TTN uplink, with inline prediction ────────────────────
model Reading {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  readingId   String   @unique          // crypto.randomUUID()
  deviceId    String
  deviceName  String   @default("")
  timestamp   DateTime                  // TTN received_at
  receivedAt  DateTime @default(now())  // server ingest time

  // Sensor values
  temperature  Float?
  ph           Float?
  tds          Float?
  turbidity    Float?
  conductivity Float?

  // LoRa metadata
  rssi            Int?
  snr             Float?
  spreadingFactor Int?

  // AI prediction saved inline
  predictionStatus     String?    // "Safe" | "Unsafe"
  predictionScore      Float?     // 0-100
  predictionRiskLevel  String?    // "Low" | "Moderate" | "High"
  predictionConfidence String?
  predictionCauses     String[]
  predictionActions    String[]
  predictionFutureRisk String?

  device Device? @relation(fields: [deviceId], references: [deviceId])

  @@index([deviceId, receivedAt(sort: Desc)])
  @@map("readings")
}

// ── ChatMessage: AI chat conversation history per device ───────────────────
model ChatMessage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  messageId   String   @unique              // crypto.randomUUID()
  deviceId    String
  role        String                        // "user" | "assistant" | "system"
  content     String                        // Message text
  timestamp   DateTime @default(now())      // When sent
  tokensUsed  Int?                          // Optional: track API usage
  model       String   @default("meta-llama/llama-3.3-70b-instruct:free")
  
  // Optional: Store context snapshot at time of message
  contextSnapshot Json?                     // { readings: [...], device: {...} }
  
  device Device? @relation(fields: [deviceId], references: [deviceId])
  
  @@index([deviceId, timestamp(sort: Desc)])
  @@map("chat_messages")
}
